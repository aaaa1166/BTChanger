<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D1117" android:padding="24dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="🔵 שינוי כתובת Bluetooth" android:textColor="#58A6FF"
        android:textSize="22sp" android:textStyle="bold" android:layout_gravity="center" android:layout_marginTop="20dp" android:layout_marginBottom="8dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="דרוש Root" android:textColor="#F0883E" android:textSize="13sp"
        android:layout_gravity="center" android:layout_marginBottom="32dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="כתובת MAC נוכחית:" android:textColor="#8B949E" android:textSize="13sp" android:layout_marginBottom="6dp"/>
    <TextView android:id="@+id/tvCurrentMac" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="טוען..." android:textColor="#E6EDF3"
        android:textSize="18sp" android:textStyle="bold" android:fontFamily="monospace"
        android:background="#161B22" android:padding="14dp" android:layout_marginBottom="28dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="כתובת MAC חדשה:" android:textColor="#8B949E" android:textSize="13sp" android:layout_marginBottom="6dp"/>
    <EditText android:id="@+id/etNewMac" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:hint="AB:CD:EF:12:34:56"
        android:hintTextColor="#484F58" android:textColor="#E6EDF3" android:textSize="16sp"
        android:fontFamily="monospace" android:background="#161B22" android:padding="14dp" android:layout_marginBottom="12dp"/>
    <Button android:id="@+id/btnRandom" android:layout_width="match_parent"
        android:layout_height="48dp" android:text="🎲 כתובת אקראית"
        android:textColor="#58A6FF" android:background="#161B22" android:layout_marginBottom="28dp"/>
    <Button android:id="@+id/btnApply" android:layout_width="match_parent"
        android:layout_height="56dp" android:text="✅ החל שינוי" android:textColor="#FFFFFF"
        android:textSize="16sp" android:textStyle="bold" android:backgroundTint="#238636" android:layout_marginBottom="20dp"/>
    <TextView android:id="@+id/tvLog" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:textSize="13sp"
        android:fontFamily="monospace" android:background="#161B22" android:padding="12dp" android:visibility="gone"/>
</LinearLayout>
